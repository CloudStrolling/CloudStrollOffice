<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.cloudstrolling.cloudoffice.auth.mapper.VerificationCodeMapper">

    <!-- 根据发送目标和用途查询最新的验证码（按创建时间降序取第一条，含逻辑删除条件） -->
    <!-- 当 purpose 为 null 时，不按用途过滤，仅按目标查询最新验证码 -->
    <select id="selectLatestByTargetAndPurpose"
            resultType="org.cloudstrolling.cloudoffice.auth.entity.VerificationCodeEntity">
        SELECT * FROM t_auth_verification_code
        WHERE target = #{target}
          AND deleted = 0
        <if test="purpose != null and purpose != ''">
            AND purpose = #{purpose}
        </if>
        ORDER BY create_time DESC
        LIMIT 1
    </select>

    <!-- 更新验证码的使用状态 -->
    <update id="updateUsedStatus">
        UPDATE t_auth_verification_code
        SET used = #{used}, used_time = #{usedTime}
        WHERE id = #{id}
    </update>

    <!-- 删除已过期的验证码记录 -->
    <delete id="deleteExpired">
        DELETE FROM t_auth_verification_code
        WHERE expire_time &lt; #{expireTime}
    </delete>

</mapper>
