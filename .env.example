# ============================================================
# 云漫智企 (CloudStrollOffice) 环境变量配置模板
# 版本: v0.1.7
# 说明: 复制此文件为 .env 并根据实际环境修改配置
# ============================================================
#
# 使用方式:
#   Linux/macOS: cp .env.example .env && source .env
#   Windows:     copy .env.example .env  (然后在 PowerShell 中 $env:VAR_NAME = "value")
#   Docker:      docker compose --env-file .env up -d
#

# ============================================================
# Nacos 配置
# ============================================================
# Nacos 服务地址 (默认: 127.0.0.1:8848)
# NACOS_ADDR=127.0.0.1:8848

# ============================================================
# MariaDB 数据库配置
# ============================================================
# MariaDB root 密码 (Docker 环境)
# MARIADB_ROOT_PASSWORD=root123

# 数据库主机地址 (Docker 环境使用服务名: mariadb)
# DB_HOST=127.0.0.1

# 数据库端口
# DB_PORT=3306

# 数据库用户名
# DB_USERNAME=root

# 数据库密码 (生产环境请使用强密码)
# DB_PASSWORD=root123

# ============================================================
# Redis 缓存配置
# ============================================================
# Redis 主机地址 (Docker 环境使用服务名: redis)
# REDIS_HOST=127.0.0.1

# Redis 端口
# REDIS_PORT=6379

# Redis 密码 (若无密码则为空)
# REDIS_PASSWORD=

# Redis 数据库编号
# REDIS_DATABASE=0

# ============================================================
# RSA 密钥配置 (JWT RS256 签名, 必需)
# ============================================================
# RSA 私钥 (Base64 编码, 生产环境必须修改)
# 生成: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform PEM -out private_key.pem
#       [Convert]::ToBase64String([IO.File]::ReadAllBytes("private_key.pem")) > private_key_base64.txt
# RSA_PRIVATE_KEY=

# RSA 公钥 (Base64 编码)
# 生成: openssl pkey -in private_key.pem -pubout -outform PEM -out public_key.pem
#       [Convert]::ToBase64String([IO.File]::ReadAllBytes("public_key.pem")) > public_key_base64.txt
# RSA_PUBLIC_KEY=

# ============================================================
# 验证码配置 (v0.1.6+)
# ============================================================
# 验证码模拟模式: true=模拟(控制台打印), false=真实发送
# VERIFICATION_CODE_MOCK=true

# 验证码过期时间 (秒, 默认 300 = 5 分钟)
# VERIFICATION_CODE_EXPIRE_SECONDS=300

# 验证码发送间隔 (秒, 默认 60)
# VERIFICATION_CODE_SEND_INTERVAL=60

# 验证码长度 (数字位数, 默认 6)
# VERIFICATION_CODE_LENGTH=6

# ============================================================
# 密码策略配置 (v0.1.6+)
# ============================================================
# 密码最小长度 (默认 8)
# PASSWORD_MIN_LENGTH=8

# 密码最大长度 (默认 64)
# PASSWORD_MAX_LENGTH=64

# ============================================================
# 时区配置
# ============================================================
# 容器时区
# TZ=Asia/Shanghai

# ============================================================
# JVM 参数 (Docker 环境)
# ============================================================
# JVM 初始堆大小
# JVM_XMS=256m

# JVM 最大堆大小
# JVM_XMX=512m
