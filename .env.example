# ============================================================
# 云漫智企 (CloudStrollOffice) 环境变量配置模板
# 版本: v0.1.0
# 说明: 复制此文件为 .env 并根据实际环境修改配置
# ============================================================

# ============================================================
# Nacos 配置
# ============================================================
# Nacos 服务地址 (默认: 127.0.0.1:8848)
# NACOS_ADDR=127.0.0.1:8848

# ============================================================
# MariaDB 数据库配置
# ============================================================
# MariaDB root 密码 (Docker 环境)
# MARIADB_ROOT_PASSWORD=root123

# 数据库主机地址 (Docker 环境使用服务名: mariadb)
# DB_HOST=127.0.0.1

# 数据库端口
# DB_PORT=3306

# 数据库用户名
# DB_USER=root

# 数据库密码 (生产环境请使用强密码)
# DB_PASSWORD=root123

# ============================================================
# JWT 令牌配置
# ============================================================
# JWT 签名密钥 (生产环境必须修改，长度 >= 32 字符)
# JWT_SECRET=your-jwt-secret-key-at-least-32-characters-long

# JWT 令牌过期时间 (毫秒, 默认: 86400000 = 24 小时)
# JWT_EXPIRATION=86400000

# ============================================================
# 时区配置
# ============================================================
# 容器时区
# TZ=Asia/Shanghai

# ============================================================
# JVM 参数 (Docker 环境)
# ============================================================
# JVM 初始堆大小
# JVM_XMS=256m

# JVM 最大堆大小
# JVM_XMX=512m
