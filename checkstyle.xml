<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
    Checkstyle 配置文件
    基于 Sun/Google 风格，融合阿里巴巴 Java 开发手册规范
    适用于 CloudStrollOffice 项目
-->

<module name="Checker">
    <!-- 文件编码 UTF-8 -->
    <property name="charset" value="UTF-8"/>

    <!-- 最大行宽 120 字符 -->
    <module name="LineLength">
        <property name="max" value="120"/>
        <property name="fileExtensions" value="java"/>
    </module>

    <!-- 文件必须包含换行符结尾 -->
    <module name="NewlineAtEndOfFile"/>

    <!-- 不允许使用 tab 缩进 -->
    <module name="FileTabCharacter">
        <property name="eachLine" value="true"/>
    </module>

    <!-- 禁用 System.out.println -->
    <module name="RegexpSingleline">
        <property name="format" value="System\.out\.println"/>
        <property name="message" value="禁止使用 System.out.println，请使用日志框架（如 SLF4J/Logback）记录日志。"/>
        <property name="severity" value="error"/>
    </module>

    <!-- TreeWalker 模块 - 树形检查 -->
    <module name="TreeWalker">

        <!-- ==================== 命名规范检查 ==================== -->

        <!-- 常量命名（大写字母和下划线） -->
        <module name="ConstantName">
            <property name="format" value="^[A-Z][A-Z0-9]*(_[A-Z0-9]+)*$"/>
        </module>

        <!-- 局部 final 变量命名 -->
        <module name="LocalFinalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 局部变量命名 -->
        <module name="LocalVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
            <property name="allowOneCharVarInForLoop" value="true"/>
        </module>

        <!-- 成员变量命名 -->
        <module name="MemberName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 方法命名 -->
        <module name="MethodName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 包命名（全部小写，点分隔） -->
        <module name="PackageName">
            <property name="format" value="^[a-z]+(\.[a-z][a-z0-9]*)*$"/>
        </module>

        <!-- 参数命名 -->
        <module name="ParameterName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 静态变量命名 -->
        <module name="StaticVariableName">
            <property name="format" value="^[a-z][a-zA-Z0-9]*$"/>
        </module>

        <!-- 类型命名（首字母大写驼峰） -->
        <module name="TypeName">
            <property name="format" value="^[A-Z][a-zA-Z0-9]*$"/>
        </module>

        <!-- ==================== 代码复杂度检查 ==================== -->

        <!-- 方法最大长度 120 行 -->
        <module name="MethodLength">
            <property name="max" value="120"/>
            <property name="countEmpty" value="false"/>
        </module>

        <!-- 参数数量最多 10 个 -->
        <module name="ParameterNumber">
            <property name="max" value="10"/>
        </module>

        <!-- 布尔表达式复杂度 -->
        <module name="BooleanExpressionComplexity">
            <property name="max" value="3"/>
        </module>

        <!-- Java NCSS（非注释源码行数）：方法级别 -->
        <module name="JavaNCSS">
            <property name="methodMaximum" value="50"/>
        </module>

        <!-- ==================== 导入检查 ==================== -->

        <!-- 导入顺序：java/javax → org → com → 静态导入 -->
        <module name="ImportOrder">
            <property name="groups" value="java, javax, org, com"/>
            <property name="ordered" value="true"/>
            <property name="separated" value="true"/>
            <property name="option" value="above"/>
            <property name="sortStaticImportsAlphabetically" value="true"/>
        </module>

        <!-- 禁止未使用的导入 -->
        <module name="UnusedImports"/>

        <!-- 禁止冗余导入 -->
        <module name="RedundantImport"/>

        <!-- ==================== 其他规则 ==================== -->

        <!-- 禁止使用星号导入 -->
        <module name="AvoidStarImport"/>

        <!-- 每行只允许一个语句 -->
        <module name="OneStatementPerLine"/>

        <!-- 每行只允许一个变量定义 -->
        <module name="MultipleVariableDeclarations"/>

        <!-- 大括号使用规范 -->
        <module name="LeftCurly"/>
        <module name="RightCurly"/>
        <module name="NeedBraces"/>

        <!-- 空块处理 -->
        <module name="EmptyBlock">
            <property name="option" value="text"/>
        </module>

        <!-- 缺失 @Override 注解 -->
        <module name="MissingOverride"/>

        <!-- switch 语句必须有 default -->
        <module name="MissingSwitchDefault"/>

        <!-- 隐藏的 catch 异常 -->
        <module name="EmptyCatchBlock">
            <property name="exceptionVariableName" value="expected|ignore"/>
        </module>

        <!-- 文件长度限制 -->
        <module name="FileLength">
            <property name="max" value="2000"/>
        </module>

    </module>

</module>
